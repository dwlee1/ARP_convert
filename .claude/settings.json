{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; case \"$f\" in */scripts/*.py) python tools/sync_addon.py ;; esac; } 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Syncing addon..."
          }
        ]
      }
    ]
  },
